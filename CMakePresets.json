{
  "version": 3,
  "configurePresets": [
    {
      "name": "macos-debug",
      "displayName": "macOS Debug (Ninja, arm64)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-debug",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/extern/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests",
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_MAKE_PROGRAM": "/opt/homebrew/bin/ninja",
        "BUILD_TESTING": "ON",
        "WARNINGS_AS_ERRORS": "ON"
      },
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/extern/vcpkg"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release (Ninja, arm64)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/extern/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests",
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_MAKE_PROGRAM": "/opt/homebrew/bin/ninja",
        "BUILD_TESTING": "ON"
      },
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/extern/vcpkg"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "win-ninja-debug",
      "displayName": "Windows Debug (Ninja + MSVC)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/win-ninja-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/extern/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/extern/vcpkg"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "win-ninja-release",
      "displayName": "Windows Release (Ninja + MSVC)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/win-ninja-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/extern/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/extern/vcpkg"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    { "name": "macos-debug-build", "configurePreset": "macos-debug" },
    { "name": "macos-release-build", "configurePreset": "macos-release" },
    { "name": "win-ninja-debug-build", "configurePreset": "win-ninja-debug" },
    { "name": "win-ninja-release-build", "configurePreset": "win-ninja-release" }
  ],
  "testPresets": [
    { "name": "macos-debug-test", "configurePreset": "macos-debug" },
    { "name": "macos-release-test", "configurePreset": "macos-release" },
    { "name": "win-ninja-debug-test", "configurePreset": "win-ninja-debug" },
    { "name": "win-ninja-release-test", "configurePreset": "win-ninja-release" }
  ]
}
